{
  "compilerOptions": {
    "target": "ES2022",
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"]
    },
    
    /* These lines fix the "allowSyntheticDefaultImports" and "TS1259" errors */
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    /* This allows Render to build the files */
    "noEmit": false
  },
  "include": ["src", "server.ts", "vite.config.ts"]
}
